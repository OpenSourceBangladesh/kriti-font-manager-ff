{
  "manifest_version": 3,
  "name": "Kriti: Bangla Font Manager",
  "short_name": "Kriti Fonts",
  "version": "1.0.0",
  "description": "Change website font to Bengali font. Browse 200+ Bangla fonts from the Kriti CDN and apply them to any website instantly.",
  "homepage_url": "https://kriti.app",
  "author": "Kriti Font Manager",

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Kriti: Bangla Font Manager",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "scripts": ["background/service-worker.js"],
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "kriti-font-manager@kriti.app",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
